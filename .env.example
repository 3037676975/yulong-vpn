# 玉龙VPN 2.0 环境变量示例
# 复制为 .env.local 本地开发使用；Vercel 部署时在 Project Settings -> Environment Variables 中填写。

# Supabase 项目地址，例如：https://xxxx.supabase.co
SUPABASE_URL=

# Supabase service_role key。只能放服务端环境变量，不能写入浏览器插件和前端页面。
SUPABASE_SERVICE_ROLE_KEY=

# 后台初始登录邮箱。上线后一定要修改。
ADMIN_EMAIL=admin@example.com

# 后台初始登录口令。上线后一定要修改，建议 12 位以上。
ADMIN_PASSWORD=please-change-this-password

# 后台 Cookie / 登录口令哈希加盐。建议随机字符串。
ADMIN_SESSION_SECRET=please-change-this-session-secret

# 动态验证码自动生成用的密钥。建议随机字符串。
YULONG_ACCESS_CODE_SECRET=please-change-this-code-secret
